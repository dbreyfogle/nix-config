{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "permission": {
    "external_directory": {
      "~/.aws/**": "deny",
      "~/.gnupg/**": "deny",
      "~/.kube/**": "deny",
      "~/.ssh/**": "deny",
      "~/Documents/**": "deny",
      "~/Library/CloudStorage/**": "deny"
    },
    "read": {
      "*": "allow",
      "**/secrets/**": "deny",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "*.envrc": "deny",
      "*id_rsa": "deny",
      "*id_ed25519": "deny",
      "*.key": "deny",
      "*.pem": "deny",
      "*.tfvars": "deny"
    }
  },
  "share": "disabled"
}
